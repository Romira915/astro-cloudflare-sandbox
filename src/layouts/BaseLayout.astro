---
import styles from "../styles/site.module.css";

type Props = { title: string };
const { title } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <main class={styles.container}>
      <slot />
    </main>
  </body>
</html>
