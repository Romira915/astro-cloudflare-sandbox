---
const links = [
  { href: "/", label: "Home" },
  { href: "/posts", label: "Posts" },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="header">
  <div class="inner">
    <a href="/" class="brand">Cloudflare Pages Test</a>
    <nav>
      <ul>
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={["nav-link", { active: isActive(link.href) }]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .inner {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-4);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .brand {
    font-weight: 700;
    color: var(--color-text);
    font-size: 1.0625rem;
  }

  .brand:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-4);
  }

  .nav-link {
    color: var(--color-text-muted);
    font-weight: 500;
    font-size: 0.9375rem;
  }

  .nav-link:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--color-primary);
  }
</style>
