---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="inner">
    <small>© {year} Cloudflare Pages Test</small>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-8);
  }

  .inner {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-4);
    text-align: center;
    color: var(--color-text-subtle);
  }
</style>
